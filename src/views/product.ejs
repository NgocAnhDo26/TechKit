<div class="bg-white p-4 rounded-lg shadow">
    <img
        src="images/products/1.png"
        alt="Product 1"
        class="w-full object-cover mb-4 rounded-lg"
    />
    <a href="/single-product-page" class="text-lg font-semibold mb-2"
        ><%= products.name %></a></a
    >
    <p class="my-2"><%= products.type %></p>
    <div class="flex items-center mb-4">
        <span class="text-lg font-bold text-primary"><%= products.price %>₫</span>
        <span class="text-sm line-through ml-2"><%= products.price %>₫</span>
    </div>
    <button
        class="bg-primary border border-transparent hover:bg-transparent hover:border-primary text-white hover:text-primary font-semibold py-2 px-4 rounded-full w-full"
    >
        Add to Cart
    </button>
</div>
